generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(cuid())
  email    String? @unique
  password String
  role     Role    @default(AGENT_NE)
  username String  @unique
}

model Shipment {
  trackingId         String         @unique
  receiverName       String
  receiverEmail      String
  receiverPhone      String?
  originCountry      String
  receiverAddress    String?
  receiverCity       String?
  receiverPoBox      String?
  destinationCountry String
  weightKg           Float?
  notes              String?
  status             ShipmentStatus @default(CREATED)
  statusHistory      Json?
  currentLocation    String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime?      @updatedAt // ✅ AJOUTEZ CETTE LIGNE

  convoyId          String?
  id                Int             @id @default(autoincrement())
  thankYouEmailSent Boolean         @default(false)

  // Infos du récupérateur au Niger (CA → NE uniquement)
  pickupLastName    String?
  pickupFirstName   String?
  pickupQuartier    String?
  pickupPhone       String?

  // Paiement
  paymentStatus     PaymentStatus   @default(UNPAID)
  amountPaid        Float?

  convoy            Convoy?         @relation(fields: [convoyId], references: [id])
  events            ShipmentEvent[]
  items             ShipmentItem[]
  payments          Payment[]
}

model ShipmentItem {
  id         String   @id @default(cuid())
  shipmentId Int
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  label      String
  quantity   Int      @default(1)
  weightKg   Float?
  createdAt  DateTime @default(now())
}

model Payment {
  id         String        @id @default(cuid())
  shipmentId Int
  shipment   Shipment      @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  amount     Float
  currency   Currency      @default(CAD)
  method     PaymentMethod @default(CASH)
  paidAt     DateTime      @default(now())
  notes      String?
  createdAt  DateTime      @default(now())
}

model Expense {
  id          String          @id @default(cuid())
  category    ExpenseCategory
  subcategory String?
  amount      Float
  currency    Currency        @default(CAD)
  date        DateTime
  convoyId    String?
  convoy      Convoy?         @relation(fields: [convoyId], references: [id])
  notes       String?
  createdAt   DateTime        @default(now())
}

model ExchangeRate {
  id        String   @id @default(cuid())
  base      String
  target    String
  rate      Float
  fetchedAt DateTime @default(now())

  @@unique([base, target])
}

model ShipmentEvent {
  id          String    @id @default(cuid())
  type        String
  description String?
  location    String?
  occurredAt  DateTime? @default(now())
  createdAt   DateTime  @default(now())
  shipmentId  Int
  shipment    Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model Convoy {
  id        String     @id @default(cuid())
  date      DateTime
  direction Direction  @default(NE_TO_CA)
  shipments Shipment[]
  expenses  Expense[]

  @@unique([date, direction])
}

enum Role {
  ADMIN
  AGENT_CA
  AGENT_NE
}

enum ShipmentStatus {
  CREATED
  RECEIVED_IN_NIGER // ✅ Statut initial pour NE→CA
  RECEIVED_IN_CANADA // ✅ Statut initial pour CA→NE
  IN_TRANSIT // En route
  IN_TRANSIT_STOP // En escale
  IN_CUSTOMS // À la douane
  READY_FOR_PICKUP // Prêt
  DELIVERED // Récupéré
}

enum Direction {
  NE_TO_CA
  CA_TO_NE
}

enum PaymentStatus {
  PAID
  PARTIAL
  UNPAID
}

enum Currency {
  CAD
  XOF
}

enum PaymentMethod {
  CASH
  TRANSFER
  MOBILE_MONEY
  OTHER
}

enum ExpenseCategory {
  SALARY
  CUSTOMS
  PACKAGING
  FUEL
  SHIPPING
  OTHER
}
