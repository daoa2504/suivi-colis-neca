generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(cuid())
  email    String? @unique
  password String
  role     Role    @default(AGENT_NE)
  username String  @unique

  // Inverse relations (audit)
  shipmentsCreated     Shipment[]        @relation("ShipmentCreatedBy")
  paymentsCreated      Payment[]         @relation("PaymentCreatedBy")
  expensesCreated      Expense[]         @relation("ExpenseCreatedBy")
  notificationsSent    NotificationLog[]
}

model Shipment {
  trackingId         String         @unique
  receiverName       String
  receiverEmail      String
  receiverPhone      String?
  originCountry      String
  receiverAddress    String?
  receiverCity       String?
  receiverPoBox      String?
  destinationCountry String
  weightKg           Float?
  notes              String?
  status             ShipmentStatus @default(CREATED)
  statusHistory      Json?
  currentLocation    String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime?      @updatedAt // ✅ AJOUTEZ CETTE LIGNE

  convoyId          String?
  id                Int             @id @default(autoincrement())
  thankYouEmailSent Boolean         @default(false)

  // Infos du récupérateur au Niger (CA → NE uniquement)
  pickupLastName    String?
  pickupFirstName   String?
  pickupQuartier    String?
  pickupPhone       String?

  // Paiement
  paymentStatus     PaymentStatus   @default(UNPAID)
  amountPaid        Float?

  // Timestamps des transitions de statut (pour la timeline publique)
  readyAt           DateTime?
  deliveredAt       DateTime?

  // Audit : qui a créé ce colis
  createdById       String?
  createdBy         User?           @relation("ShipmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  convoy            Convoy?         @relation(fields: [convoyId], references: [id])
  events            ShipmentEvent[]
  items             ShipmentItem[]
  payments          Payment[]
}

model ShipmentItem {
  id         String   @id @default(cuid())
  shipmentId Int
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  label      String
  quantity   Int      @default(1)
  weightKg   Float?
  createdAt  DateTime @default(now())
}

model Payment {
  id          String        @id @default(cuid())
  shipmentId  Int
  shipment    Shipment      @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  amount      Float
  currency    Currency      @default(CAD)
  method      PaymentMethod @default(CASH)
  paidAt      DateTime      @default(now())
  notes       String?
  createdAt   DateTime      @default(now())

  // Audit : qui a saisi ce paiement
  createdById String?
  createdBy   User?         @relation("PaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
}

model Expense {
  id          String          @id @default(cuid())
  category    ExpenseCategory
  subcategory String?
  amount      Float
  currency    Currency        @default(CAD)
  date        DateTime
  convoyId    String?
  convoy      Convoy?         @relation(fields: [convoyId], references: [id])
  notes       String?
  createdAt   DateTime        @default(now())

  // Audit : qui a saisi cette dépense
  createdById String?
  createdBy   User?           @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
}

model ExchangeRate {
  id        String   @id @default(cuid())
  base      String
  target    String
  rate      Float
  fetchedAt DateTime @default(now())

  @@unique([base, target])
}

// Journal des notifications envoyées par les utilisateurs
model NotificationLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Type de notification : CONVOY (template EN_ROUTE / IN_CUSTOMS / OUT_FOR_DELIVERY)
  // ou DELIVERED (remerciement individuel)
  type       String
  template   String?
  convoyId   String?
  shipmentId Int?
  sentCount  Int      @default(0)
  failedCount Int     @default(0)
  notes      String?
  createdAt  DateTime @default(now())
}

model ShipmentEvent {
  id          String    @id @default(cuid())
  type        String
  description String?
  location    String?
  occurredAt  DateTime? @default(now())
  createdAt   DateTime  @default(now())
  shipmentId  Int
  shipment    Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model Convoy {
  id        String     @id @default(cuid())
  date      DateTime
  direction Direction  @default(NE_TO_CA)
  shipments Shipment[]
  expenses  Expense[]

  @@unique([date, direction])
}

enum Role {
  ADMIN
  AGENT_CA
  AGENT_NE
}

enum ShipmentStatus {
  CREATED
  RECEIVED_IN_NIGER // ✅ Statut initial pour NE→CA
  RECEIVED_IN_CANADA // ✅ Statut initial pour CA→NE
  IN_TRANSIT // En route
  IN_TRANSIT_STOP // En escale
  IN_CUSTOMS // À la douane
  READY_FOR_PICKUP // Prêt
  DELIVERED // Récupéré
}

enum Direction {
  NE_TO_CA
  CA_TO_NE
}

enum PaymentStatus {
  PAID
  PARTIAL
  UNPAID
}

enum Currency {
  CAD
  XOF
}

enum PaymentMethod {
  CASH
  TRANSFER
  MOBILE_MONEY
  OTHER
}

enum ExpenseCategory {
  SALARY
  CUSTOMS
  PACKAGING
  FUEL
  SHIPPING
  OTHER
}

// ============================================================================
// FONDATIONS FISCALES (Phase 1)
// ============================================================================

// Régimes fiscaux appliqués à une transaction
enum TaxRegime {
  TAX_INCLUDED   // Taxes comprises dans le prix annoncé
  TAX_EXCLUDED   // Taxes ajoutées au prix annoncé
  ZERO_RATED     // Service taxable au taux de 0 %
  TAX_EXEMPT     // Aucune taxe applicable
  OUT_OF_SCOPE   // Hors du champ d'application des taxes
}

// Profil de l'entreprise (singleton — une seule ligne active à la fois)
model CompanyProfile {
  id              String   @id @default(cuid())
  legalName       String                       // "NIMAPLEX INC." (dénomination sociale)
  displayName     String                       // "NIMAPLEX" (nom d'usage)
  neq             String?                      // Numéro d'entreprise du Québec
  gstNumber       String?                      // Numéro TPS (RT0001)
  qstNumber       String?                      // Numéro TVQ (TQ0001)
  address         String
  city            String
  province        String
  postalCode      String
  country         String   @default("Canada")
  email           String?
  phone           String?
  registeredAt    DateTime                     // Date d'incorporation
  fiscalYearStart Int      @default(1)         // Mois de début (1-12) — utile pour rapports annuels
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Taux de taxes configurables (TPS, TVQ, TVH, etc.)
// L'immutabilité passe par les colonnes validFrom/validTo et par le fait
// qu'une facture émise stocke un snapshot du taux dans TaxSnapshot (Phase 2)
model TaxRate {
  id           String    @id @default(cuid())
  name         String                          // "TPS", "TVQ", "TVH-ON"
  code         String                          // Code fonctionnel : "GST", "QST", "HST"
  rate         Decimal   @db.Decimal(7, 5)     // 0.05000, 0.09975 (max 99.99999) — 5 décimales pour taux comme TVQ 9,975 %
  jurisdiction String                          // "CA-federal", "CA-QC", "CA-ON"
  validFrom    DateTime                        // Date d'entrée en vigueur
  validTo      DateTime?                       // Date de fin (null = pas de fin)
  active       Boolean   @default(true)
  notes        String?                         // Ex: "TPS fédérale — Loi sur la taxe d'accise"
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([code, active])
  @@index([jurisdiction, active])
}

// Règles fiscales configurables — moteur de détermination du régime applicable
// Chaque règle a une priorité (plus haute = évaluée en premier)
// La première règle dont tous les critères remplis s'applique
model TaxRule {
  id                 String    @id @default(cuid())
  name               String                     // "Transport international CA→NE"
  priority           Int       @default(0)      // Plus haut = évalué en premier
  originCountry      String?                    // Code pays : "CA", "NE" — null = n'importe
  destinationCountry String?                    // Code pays destination — null = n'importe
  clientProvince     String?                    // "QC", "ON", ... — null = n'importe
  serviceType        String?                    // "SHIPPING", "STORAGE", "OTHER" — null = n'importe
  regime             TaxRegime                  // Régime fiscal à appliquer
  taxRateCodes       String[]                   // Codes de TaxRate à appliquer (ex: ["GST","QST"])
  notes              String?                    // Justification légale, référence loi/annexe
  active             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([active, priority])
}

// Journal d'audit générique — utilisable pour n'importe quelle entité
// À utiliser via lib/audit.ts::logAudit()
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  entityType String                              // "Invoice", "Expense", "TaxRate", "CompanyProfile"
  entityId   String                              // ID de l'entité concernée
  action     String                              // "CREATE", "UPDATE", "CANCEL", "REFUND", "DELETE", "LOGIN"
  before     Json?                               // Snapshot avant modification
  after      Json?                               // Snapshot après modification
  reason     String?                             // Raison utilisateur (annulation, remboursement)
  ipAddress  String?                             // Utile pour actions sensibles
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}
